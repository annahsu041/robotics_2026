<launch>
    <!--
      視覺感知多旋翼機系統架構 Launch 檔 (骨架範例)
      整合 MAVROS, VIO (OpenVINS), EKF, 規劃器, 與視覺降落
    -->

    <!-- 1. MAVROS 節點 (連接 PX4 SITL) -->
    <include file="$(find mavros)/launch/px4.launch">
        <arg name="fcu_url" value="udp://:14540@127.0.0.1:14557" />
    </include>

    <!-- 2. 視覺慣性里程計 (以 OpenVINS 為例) -->
    <node pkg="open_vins" type="ov_msckf" name="ov_msckf" output="screen">
        <!-- 這裡需替換為您對應相機與 IMU 的 yaml 設定檔 -->
        <!-- <param name="config_path" value="$(find your_pkg)/config/openvins_config.yaml" /> -->
    </node>

    <!-- 3. 感測器融合 (robot_localization 雙 EKF 範例) -->
    <node pkg="robot_localization" type="ekf_localization_node" name="ekf_local" clear_params="true">
        <!-- 載入融合設定 (融合 VIO odom + IMU) -->
        <!-- <rosparam command="load" file="$(find your_pkg)/config/ekf_local.yaml" /> -->
        <remap from="odometry/filtered" to="/odom_world" />
    </node>

    <!-- 4. 即時軌跡重規劃 (Ego-Planner) -->
    <!-- 通常 Ego-Planner 會自帶 launch，這裡示範 Include 方式 -->
    <!-- <include file="$(find ego_planner)/launch/simple_run.launch" /> -->

    <!-- 5. AprilTag 偵測 (apriltag_ros) -->
    <include file="$(find apriltag_ros)/launch/continuous_detection.launch">
        <arg name="camera_name" value="/iris/cam_down" /> <!-- 向下相機 -->
        <arg name="image_topic" value="image_raw" />
        <!-- <arg name="settings_extension" value="" /> -->
        <!-- <arg name="tags_extension" value="" /> -->
    </include>

    <!-- 6. 狀態機控制節點 (FSM) -->
    <node pkg="your_pkg" type="drone_fsm.py" name="drone_fsm" output="screen" />

</launch>
